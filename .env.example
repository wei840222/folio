# Folio runtime config example
# Copy to .env and adapt values for your environment.

# Core
FOLIO_WEB_PATH=./web/dist
FOLIO_UPLOADS_PATH=./uploads

# Cloudflare Access private file auth
FOLIO_CF_ACCESS_ISSUER=https://<team>.cloudflareaccess.com
FOLIO_CF_ACCESS_AUD=<your-access-audience>
# Optional override; default is ${FOLIO_CF_ACCESS_ISSUER}/cdn-cgi/access/certs
FOLIO_CF_ACCESS_JWKS_URL=https://<team>.cloudflareaccess.com/cdn-cgi/access/certs

# Optional allowlists (comma-separated)
FOLIO_CF_ACCESS_ALLOWED_EMAILS=alice@example.com,bob@example.com
FOLIO_CF_ACCESS_ALLOWED_GROUPS=folio-admins,folio-readers

# Optional local/dev testing verifier mode (HS256)
# Do NOT enable in production unless explicitly intended.
# FOLIO_CF_ACCESS_HS256_SECRET=replace-with-dev-secret
